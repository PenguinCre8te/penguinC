#import std.io;
int main() {
    int a = 10;
    int b = 3;
    io.print_int(a + b);
    io.print("\n");
    io.print_int(a - b);
    io.print("\n");
    io.print_int(a * b);
    io.print("\n");
    io.print_int(a / b);
    io.print("\n");
    io.print_int(a % b);
    io.print("\n");
    return 0;
}
