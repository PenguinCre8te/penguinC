#import std.console;
class Base {
    int id;

    void new(int i) {
        self.id = i;
    }
}

class Derived extends Base {
    int extra;

    void new(int i, int e) {
        super.new(i);
        self.extra = e;
    }
}

int main() {
    Derived d = new Derived(1, 2);
    console.print_int(d.id);
    console.print(" ");
    console.println_int(d.extra);
    return 0;
}
