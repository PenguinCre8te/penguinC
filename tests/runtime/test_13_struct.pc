#import std.console;
struct Point {
    int x;
    int y;
}

int main() {
    mut Point p = {10, 20};
    console.print_int(p.x);
    console.print(" ");
    console.println_int(p.y);
    p.x = 30;
    p.y = 40;
    console.print_int(p.x);
    console.print(" ");
    console.println_int(p.y);
    return 0;
}
