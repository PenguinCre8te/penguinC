#import std.io;
int main() {
    mut int sum = 0;
    for i in 0..10 {
        if i == 5 {
            break;
        }
        sum += i;
    }
    io.println_int(sum);
    mut int count = 0;
    for i in 0..10 {
        if i % 2 == 0 {
            continue;
        }
        count += 1;
    }
    io.println_int(count);
    return 0;
}
