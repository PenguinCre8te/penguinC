#import std.console;
int main() {
    int a = 10;
    int b = 3;
    console.print_int(a + b);
    console.print("\n");
    console.print_int(a - b);
    console.print("\n");
    console.print_int(a * b);
    console.print("\n");
    console.print_int(a / b);
    console.print("\n");
    console.print_int(a % b);
    console.print("\n");
    return 0;
}
