#import std.io;
int main() {
    int result = 25;
    match (result) {
        case result in 0..10 { io.println("small") }
        case result in 10..50 { io.println("medium") }
        case result > 50 { io.println("large") }
        case * { io.println("unknown") }
    }
    int big = 75;
    match (big) {
        case big in 0..50 { io.println("small") }
        case big > 50 { io.println("large") }
        case * { io.println("unknown") }
    }
    return 0;
}
