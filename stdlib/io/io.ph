#link "./io.o";

void print(string s) => io_print;
void println(string s) => io_println;
void print_int(long val) => io_print_int;
void println_int(long val) => io_println_int;
void program_exit(long code) => program_exit_c;
long penguin_strlen(string s) => penguin_strlen;
string str_concat(string a, string b) => penguin_str_concat;
